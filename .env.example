# Kraken API
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

# Kraken CLI Path (for server-side execution)
KRAKEN_CLI_PATH=/home/fataakromulm/ruangkerja/dashboard-trading/kraken-cli/target/release/kraken

# Hermes LLM (local atau remote)
LLM_BASE_URL=http://localhost:11434/v1   # jika local (Ollama)
LLM_API_KEY=ollama                        # atau API key jika hosted
LLM_MODEL=hermes3                         # nama model

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENT_ENABLED=false                       # safety: default off
AGENT_MAX_TRADE_USD=50                    # limit per trade saat autonomous
AGENT_CHECK_INTERVAL_SECONDS=60

# WebSocket (jika pakai external WS server)
WS_SERVER_URL=wss://your-ws.railway.app
